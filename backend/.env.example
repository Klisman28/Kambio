# Kambio Backend — Variables de entorno
# Copia este archivo a .env y completa los valores reales
# NUNCA subas .env al repositorio

# Base de datos (Hostinger producción)
DATABASE_URL=mysql+pymysql://u530329005_kambio:TU_PASSWORD@srv910.hstgr.io:3306/u530329005_allkambio

# Base de datos (desarrollo local con Docker)
# DATABASE_URL=mysql+pymysql://kambio:kambio_dev@localhost:3306/kambio_db

# JWT
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# CORS
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Admin semilla (solo para desarrollo)
SEED_ADMIN_EMAIL=admin@kambio.dev
SEED_ADMIN_PASSWORD=CHANGE_IN_PRODUCTION
