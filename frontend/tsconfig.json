{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@theme/*": ["./src/theme/*"],
      "@modules/*": ["./src/modules/*"]
    },
    "strict": true,
    "noImplicitAny": false,
    "verbatimModuleSyntax": false
  },
  "exclude": [
    "src/theme/__mock__/**/*",
    "src/theme/auth/firebase.ts",
    "src/theme/auth/useAuth.ts",
    "src/theme/lib/libPhoneNumber.ts",
    "src/theme/sections/products/product-form/ProductImages.vue",
    "src/theme/sections/users/UserImageUpload.vue"
  ]
}
